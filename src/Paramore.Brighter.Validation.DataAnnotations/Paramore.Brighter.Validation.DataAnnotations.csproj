<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>System.ComponentModel.DataAnnotations integration for Paramore.Brighter. Validates request inputs in the Brighter request pipeline before the business handler runs, via the [ValidateRequest] attribute and a ValidateRequestHandler that validates the request against its DataAnnotations attributes.</Description>
    <TargetFrameworks>$(BrighterTargetFrameworks)</TargetFrameworks>
    <PackageTags>DataAnnotations;Validation;Command Processor;Pipeline;Brighter</PackageTags>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Paramore.Brighter\Paramore.Brighter.csproj" />
    <ProjectReference Include="..\Paramore.Brighter.Extensions.DependencyInjection\Paramore.Brighter.Extensions.DependencyInjection.csproj" />
  </ItemGroup>

</Project>
