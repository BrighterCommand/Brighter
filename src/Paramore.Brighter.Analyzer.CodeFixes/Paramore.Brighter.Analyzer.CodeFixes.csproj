<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>$(BrighterNetStandardTargetFrameworks)</TargetFrameworks>
    <Authors>Rafael Andrade</Authors>
    <Description>Code fixes for the brighter library analyzers</Description>
    <PackageTags>Analyzer;CodeFix;Command Processor;Brighter</PackageTags>
    <IsPackable>false</IsPackable>
    <DevelopmentDependency>true</DevelopmentDependency>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Paramore.Brighter.Analyzer\Paramore.Brighter.Analyzer.csproj" />
  </ItemGroup>

</Project>
