<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Oracle Database outbox implementation for Paramore.Brighter Command Processor. Provides reliable message publishing with outbox pattern using Oracle for transactional consistency and guaranteed delivery.</Description>
    <Authors>Rafael Andrade</Authors>
    <TargetFrameworks>$(BrighterMongoTargetFrameworks)</TargetFrameworks>
    <PackageTags>Oracle;Oracle Database;Database;Outbox;Transactional;Command;Event;Service Activator;Decoupled;Invocation;Messaging;Remote;Command Dispatcher;Command Processor;Request;Service;Task Queue;Work Queue;Retry;Circuit Breaker;Availability;Brighter</PackageTags>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Paramore.Brighter.Oracle\Paramore.Brighter.Oracle.csproj" />
    <ProjectReference Include="..\Paramore.Brighter\Paramore.Brighter.csproj" />
  </ItemGroup>
</Project>
