<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>PostgreSQL box provisioning for Paramore.Brighter. Provides automatic creation and migration of inbox and outbox tables in PostgreSQL at application startup.</Description>
    <Authors>Ian Cooper</Authors>
    <TargetFrameworks>$(BrighterCoreTargetFrameworks)</TargetFrameworks>
    <PackageTags>PostgreSQL;Postgres;Database;Outbox;Inbox;Provisioning;Migration;Command;Event;Command Processor;Messaging;Brighter</PackageTags>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Paramore.Brighter.BoxProvisioning\Paramore.Brighter.BoxProvisioning.csproj"/>
    <ProjectReference Include="..\Paramore.Brighter.Inbox.Postgres\Paramore.Brighter.Inbox.Postgres.csproj"/>
    <ProjectReference Include="..\Paramore.Brighter.Outbox.PostgreSql\Paramore.Brighter.Outbox.PostgreSql.csproj"/>
    <ProjectReference Include="..\Paramore.Brighter\Paramore.Brighter.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Npgsql"/>
  </ItemGroup>

</Project>
