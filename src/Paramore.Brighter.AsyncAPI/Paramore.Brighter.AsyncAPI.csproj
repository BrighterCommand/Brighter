<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>AsyncAPI 3.0 document generation for Paramore.Brighter. Auto-generates AsyncAPI specifications from registered subscriptions, publications, and assembly-scanned message types.</Description>
    <TargetFrameworks>$(BrighterCoreTargetFrameworks)</TargetFrameworks>
    <SignAssembly>false</SignAssembly>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"/>
    <PackageReference Include="Neuroglia.AsyncApi.Core"/>
    <PackageReference Include="Neuroglia.AsyncApi.IO"/>
    <PackageReference Include="System.Text.Json"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Paramore.Brighter\Paramore.Brighter.csproj"/>
    <ProjectReference Include="..\Paramore.Brighter.Extensions.DependencyInjection\Paramore.Brighter.Extensions.DependencyInjection.csproj"/>
  </ItemGroup>
</Project>
